exports[`doubleshot Vite Plugin > plugin's config should be overridden by \`configureForMode\` > should match snapshot in development mode 1`] = `
"let node_path = require("node:path");
let electron = require("electron");

//#region src/index.ts
function createWindow() {
	const isDev = !electron.app.isPackaged;
	const win = new electron.BrowserWindow({
		width: 800,
		height: 600,
		webPreferences: {
			contextIsolation: true,
			preload: (0, node_path.join)(__dirname, "./preload.js")
		}
	});
	electron.ipcMain.handle("msg", (_, msg) => {
		console.log(msg);
		electron.app.quit();
	});
	const URL = isDev ? "http://127.0.0.1:12345/" : \`file://\${(0, node_path.join)(electron.app.getAppPath(), "dist/renderer/index.html")}\`;
	win.loadURL(URL);
}
electron.app.whenReady().then(() => {
	createWindow();
});
electron.app.on("window-all-closed", () => {
	if (process.platform !== "darwin") electron.app.quit();
});

//#endregion"
`;

